#!/usr/bin/env python3
from pathlib import Path
import runpy
import sys

SCRIPT_PATH = Path("/workspace/archive_files.py")
if not SCRIPT_PATH.exists():
    print("Error: /workspace/archive_files.py not found.", file=sys.stderr)
    raise SystemExit(1)

sys.path.insert(0, str(SCRIPT_PATH.parent))
runpy.run_path(str(SCRIPT_PATH), run_name="__main__")
